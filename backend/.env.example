# StockPro 生产环境变量示例（复制为 backend/.env，勿提交真实密钥）

# AI（智能选股功能必填）
QWEN_API_KEY=your-qwen-api-key
QWEN_STOCK_MODEL=qwen-plus

# 管理后台登录
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_TOKEN_SECRET=change-this-random-secret
ADMIN_TOKEN_TTL_SECONDS=43200

# 数据与运行时（云端 B/S 生产使用 Postgres）
AKSHARE_TIMEOUT=30
DB_MODE=postgres
DATABASE_URL=postgresql://stockpro_app:change-me@127.0.0.1:5432/stockpro_prod

# 功能开关
ENABLE_SCHEDULER=false
ENABLE_REALTIME_SYNC=false
ENABLE_STRATEGY_EXECUTION=false
ENABLE_EXTERNAL_MARKET_FETCH=true
ENABLE_LEGACY_SQLITE_MODULES=false

# CORS（按实际访问地址调整）
# 本地开发: ["http://localhost:4444"]
# 生产环境: ["http://47.79.36.92:4444"]
BACKEND_CORS_ORIGINS=["http://47.79.36.92:4444"]

# 可选 Supabase
# SUPABASE_URL=
# SUPABASE_KEY=
# SUPABASE_SERVICE_KEY=
