#!/bin/bash
# Get the absolute path of the script directory
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
# Go up to the app root (StockApp.app/Contents/MacOS -> StockApp.app/.. -> stock_app)
PROJECT_ROOT="$DIR/../../.."

# Check if we are in the right place
if [ -f "$PROJECT_ROOT/start_app.sh" ]; then
    cd "$PROJECT_ROOT"
    # Execute the start script
    # Use Terminal to run it so user can see output and close it
    open -a Terminal "$PROJECT_ROOT/start_app.sh"
else
    # Fallback if moved
    osascript -e 'display notification "Could not find start_app.sh" with title "StockApp Error"'
fi
